# Team Agent Configuration

# Server
HOST=0.0.0.0
PORT=8200
DEBUG=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/team_agent.db

# Encryption key for API keys (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
ENCRYPTION_KEY=

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Default LLM Provider (optional, users configure their own)
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini

# Budget
DEFAULT_SESSION_BUDGET_USD=10.0
