{
  "name": "team-agent-frontend",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "desktop:dev": "electron .",
    "desktop:pack": "npm run build && electron-builder --dir",
    "desktop:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.0",
    "shadcn": "^4.4.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "electron": "^39.2.4",
    "electron-builder": "^26.0.12",
    "@types/react": "^19.0.0",
    "postcss": "^8.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0"
  },
  "build": {
    "appId": "com.teamagent.desktop",
    "productName": "FlowPilot",
    "icon": "electron/assets/icon.png",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "electron/**/*",
      ".next/**/*",
      "public/**/*",
      "next.config.ts",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "app/**/*",
          "requirements.txt"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
